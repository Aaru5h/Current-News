# ─────────────────────────────────────────────────────────────────────────────
#  .env.example  —  Environment variable template for Agent 1 Predictor
#
#  HOW TO USE:
#    1. Copy this file:   cp .env.example .env
#    2. Fill in your real API keys below
#    3. Never commit the .env file (it is already in .gitignore)
#
#  MINIMUM REQUIRED:
#    - FYERS_APP_ID + FYERS_SECRET_KEY  → to fetch Indian market data
#    - Run fyers_mcp_auth.py once       → auto-fills FYERS_ACCESS_TOKEN daily
#
#  OPTIONAL (for LLM reasoning):
#    - OPENAI_API_KEY or OPENROUTER_API_KEY or GOOGLE_API_KEY
#    - The agent falls back to deterministic reasoning if none are set
# ─────────────────────────────────────────────────────────────────────────────


# --- LLM Providers (reasoning engine — at least one recommended) ---
OPENAI_API_KEY=your_openai_api_key_here
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_API_KEY_2=your_openrouter_api_key_2_here
GOOGLE_API_KEY=your_google_gemini_api_key_here

# --- Market Data (US stocks via AlphaVantage) ---
ALPHAVANTAGE_API_KEY=your_alphavantage_api_key_here

# --- Paper Trading (Alpaca — optional, only needed for PAPER mode) ---
ALPACA_API_KEY=your_alpaca_api_key_here
ALPACA_SECRET_KEY=your_alpaca_secret_key_here
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# --- Fyers (Indian Markets: NSE/BSE — REQUIRED for India mode) ---
# Get your App ID and Secret from: https://myapi.fyers.in/dashboard
FYERS_APP_ID=YOUR_APP_ID-100
FYERS_SECRET_KEY=your_fyers_secret_key_here
# Run fyers_mcp_auth.py daily to auto-fill this token (expires every 24h):
FYERS_ACCESS_TOKEN=your_fyers_access_token_here
